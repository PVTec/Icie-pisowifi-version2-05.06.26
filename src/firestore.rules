
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth.uid == 'sfyucpMMRPeCmDnoa4LEz3Cvoon1';
    }
    
    function isParticipant(conversationId) {
        return request.auth.uid in conversationId.split('_');
    }

    function isPlayer(game) {
      return request.auth.uid == game.data.player1Id || request.auth.uid == game.data.player2Id;
    }
    
    function isPlayer1(game) {
        return request.auth.uid == game.data.player1Id;
    }
    
    function isPlayer2(game) {
      return request.auth.uid == game.data.player2Id;
    }

    // --- User Data Rules ---
    match /users/{userId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      // Allow user to update their own profile fields.
      // Allow admin to update any field.
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;

      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin(); // Allow users to create their own transaction logs
        allow update, delete: if false; // Transactions are immutable
      }
    }
    
    // --- Publicly Readable Data ---
    match /voucher_templates/{templateId} {
      allow read, list: if request.auth != null;
      allow create, update, delete: if isAdmin();
      
      match /voucher_codes/{codeId} {
        allow read, list, create, delete: if isAdmin();
        // Allow authenticated users to get/update (to use) a code. This is needed for the purchase transaction.
        allow get, update: if request.auth != null;
      }
    }
    
    match /credit_codes/{codeId} {
      allow read, list, create, update, delete: if isAdmin();
      allow get, update: if request.auth != null;
    }

    // --- Chat Rules ---
    match /chat_messages/{messageId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }
    
    match /private_chats/{conversationId}/messages/{messageId} {
        allow read, create, update: if isParticipant(conversationId);
        allow delete: if false;
    }

    // --- Game Rules ---
    match /tic_tac_toe_games/{gameId} {
      allow create: if request.auth != null;
      allow read, update: if isPlayer(resource);
      
      allow delete: if (isPlayer1(resource) && (resource.data.status == 'declined' || resource.data.status == 'cancelled')) ||
                       (isPlayer2(resource) && resource.data.status == 'pending');
    }
  }
}
